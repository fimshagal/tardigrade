{
  "compilerOptions": {
    "target": "esnext",
    "module": "esnext",
    "declaration": true,
    "declarationDir": "./dist",
    "emitDeclarationOnly": true,
    "outDir": "./dist",
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "noImplicitAny": true,
    "skipLibCheck": true,
    "moduleResolution": "Node",
    "baseUrl": ".",
    "paths": {
      "tardigrade-store": ["./sources/index.ts"],
      "tardigrade-store/persist": ["./sources/persist/index.ts"],
      "tardigrade-store/history": ["./sources/history/index.ts"],
      "tardigrade-store/ward": ["./sources/ward/index.ts"]
    }
  },
  "include": ["sources/**/*.ts"],
  "exclude": ["node_modules", "dist"]
}
